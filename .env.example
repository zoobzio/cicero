# =============================================================================
# Application
# =============================================================================
APP_PORT=8080

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
APP_DB_HOST=localhost
APP_DB_PORT=5432
APP_DB_NAME=cicero
APP_DB_USER=cicero
APP_DB_PASSWORD=cicero
APP_DB_SSLMODE=disable

# =============================================================================
# Translator (LibreTranslate sidecar)
# =============================================================================
APP_TRANSLATOR_ADDR=http://localhost:5000

# =============================================================================
# Observability (OTEL)
# =============================================================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=cicero
